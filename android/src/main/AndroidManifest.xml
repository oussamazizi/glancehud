<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Float the overlay over the whole device (granted at runtime). -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!--
      The foreground-service permissions and <service> declaration live in the
      optional :service module, so apps that only use the attached overlay don't
      inherit them. Add com.glancehud.service (GlancePersistentHud) to opt in.
    -->

</manifest>
